{
  "name": "@permissionlabs/claw-farm",
  "version": "0.2.0",
  "description": "Multi OpenClaw instance manager — scaffold, run, and deploy AI agents with persistent memory",
  "type": "module",
  "exports": {
    ".": {
      "bun": "./src/lib/api.ts",
      "types": "./dist/lib/api.d.ts",
      "default": "./dist/lib/api.js"
    },
    "./security": {
      "bun": "./src/sdk/index.ts",
      "types": "./dist/sdk/index.d.ts",
      "default": "./dist/sdk/index.js"
    },
    "./security/patterns": {
      "bun": "./src/sdk/patterns/index.ts",
      "types": "./dist/sdk/patterns/index.d.ts",
      "default": "./dist/sdk/patterns/index.js"
    },
    "./security/providers": {
      "bun": "./src/sdk/providers/index.ts",
      "types": "./dist/sdk/providers/index.d.ts",
      "default": "./dist/sdk/providers/index.js"
    }
  },
  "bin": {
    "claw-farm": "./src/index.ts"
  },
  "files": ["src/", "dist/"],
  "scripts": {
    "dev": "bun run src/index.ts",
    "build": "bun run scripts/build.ts",
    "typecheck": "tsc --noEmit",
    "test": "bun test"
  },
  "keywords": ["openclaw", "ai-agent", "docker", "memory", "cli"],
  "license": "MIT",
  "author": "PermissionLabs",
  "repository": {
    "type": "git",
    "url": "https://github.com/PermissionLabs/claw-farm"
  },
  "devDependencies": {
    "bun-types": "^1.3.11",
    "typescript": "^5.9.3"
  }
}
